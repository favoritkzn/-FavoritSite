# Database
DATABASE_URL="postgresql://favorit:favorit@localhost:5432/favorit?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-use-rs256-key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=4000
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="/api/v1"

# Web
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ФК «Фаворит»"

# S3 / MinIO (dev)
S3_ENDPOINT="http://localhost:9000"
# Public URL for Next.js images in production (e.g. https://media.favorit-kzn.ru)
NEXT_PUBLIC_S3_URL=""
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="favorit-media"
S3_REGION="us-east-1"
# Set to true when MinIO is running (bash scripts/docker-up.sh)
S3_ENABLED="true"

# ЮKassa (payments — configure in production)
YUKASSA_SHOP_ID=""
YUKASSA_SECRET_KEY=""

# Email
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@favorit-kzn.ru"

# Environment
NODE_ENV="development"
